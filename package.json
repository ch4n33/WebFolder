{
  "name": "webfolder",
  "version": "2.0.0",
  "description": "공유 PC에서 S3-compatible 스토리지로 빠르게 파일을 업로드하는 서비스",
  "main": "backend/src/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "migrate": "node backend/src/db/migrate.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/integration",
    "test:security": "vitest run tests/security",
    "test:watch": "vitest"
  },
  "keywords": ["file-upload", "s3", "otp", "qr-auth"],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "qrcode": "^1.5.3",
    "express-rate-limit": "^7.1.5",
    "pg": "^8.13.1",
    "@aws-sdk/client-s3": "^3.700.0",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.7",
    "bcrypt": "^5.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "vitest": "^2.1.8",
    "supertest": "^7.0.0"
  }
}
